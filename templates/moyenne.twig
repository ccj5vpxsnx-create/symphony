{% extends 'base.html.twig' %}

{% block title %}Moyenne{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Moyenne</h1>

    <p>Note 1 : {{ note1 }}</p>
    <p>Note 2 : {{ note2 }}</p>

    <div class="alert {% if moyenne >= 10 %}alert-success{% else %}alert-danger{% endif %}">
        <strong>Moyenne : {{ moyenne }}/20</strong>
    </div>

    <a href="{{ path('app_home_page') }}" class="btn btn-secondary mt-3">Retour</a>
</div>
{% endblock %}